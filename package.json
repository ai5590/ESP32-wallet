{
  "name": "esp-wallet-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Solana wallet WebExtension MVP",
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build:chromium": "node ./scripts/build.mjs chromium",
    "build:firefox": "node ./scripts/build.mjs firefox",
    "build": "npm run build:chromium && npm run build:firefox",
    "build:site": "npm run build && node ./scripts/build-site.mjs"
  },
  "dependencies": {
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/web3.js": "^1.98.4",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "@wallet-standard/wallet": "^1.1.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.294",
    "@types/node": "^22.15.2",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3"
  }
}
